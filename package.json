{
  "name": "operator",
  "productName": "Operator",
  "version": "1.0.0",
  "description": "Tactical Barbell Operator companion — picks your weekly weights and exports your calendar.",
  "author": "Dimitar",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "node --test tests/",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.dimitar.operator",
    "productName": "Operator",
    "files": [
      "index.html",
      "js/**",
      "main.js",
      "package.json"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns",
      "identity": null,
      "category": "public.app-category.healthcare-fitness"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png",
      "category": "Utility"
    }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^25.0.0"
  }
}
